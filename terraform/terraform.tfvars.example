# Copy to terraform.tfvars for local use. Never commit real secrets.

name                = "devbox1"
username            = "youruser"
ssh_public_key_path = "~/.ssh/id_rsa_personal.pub"

# Usually generated by scripts/choose-vm.py into terraform.auto.tfvars.json.
server_type = "cx23"
location    = "fsn1"
image       = "ubuntu-24.04"

# Keep Tailscale auth keys out of tfvars. Put this in .env instead:
# export TF_VAR_tailscale_auth_key="tskey-auth-..."
# Do not set tailscale_auth_key here unless intentionally overriding the env var.

# Add this when the public GitHub repo is ready.
dotfiles_repo_url       = "https://github.com/manishtrouble/myvmkit.git"
dotfiles_bootstrap_path = "dotfiles/bootstrap.sh"

# Keep empty for normal Tailscale-only access.
# For temporary break-glass access, use your current public IP as CIDR, e.g. ["203.0.113.10/32"].
allow_public_ssh_cidrs = []

labels = {
  owner = "youruser"
}
